# .env.example — Copy this to .env and fill in your values
# NEVER commit the .env file to git (it's in .gitignore)

# Your Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# URL of the running environment server
# Default: http://localhost:8000 (local)
# For Hugging Face Spaces: https://your-space-name.hf.space
ENV_SERVER_URL=http://localhost:8000

# Which task to run (1=easy, 2=medium, 3=hard)
TASK_ID=1
